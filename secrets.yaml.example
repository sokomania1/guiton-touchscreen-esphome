# Kopiere diese Datei zu 'secrets.yaml' und fülle deine Werte ein

# WiFi Credentials
wifi_ssid: "DeinWiFiName"
wifi_password: "DeinWiFiPasswort"

# Optional: OTA Password
ota_password: "esphome"

# Optional: API Encryption Key (generiert mit 'esphome secrets --generate')
api_encryption_key: "dein_verschlüsselungs_key"
