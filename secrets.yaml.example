# Kopiere diese Datei zu 'secrets.yaml' und fülle deine Werte ein

# WiFi Credentials
wifi_ssid: "DeinWiFiName"
wifi_password: "DeinWiFiPasswort"

# OTA Password (für Updates über WiFi)
ota_password: "esphome123"

# API Encryption Key (generiere mit: esphome secrets --generate)
# Oder kopiere aus Home Assistant nach erstem Flash
api_encryption_key: "dein_32_zeichen_langer_key_hier"
